// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_NODE")
}

model StubTableNode {
  @@map("stub_table_node")
  id      Int      @id @default(autoincrement())
  name    String
 }
